# Copy this file to secret.env (which is gitignored) and fill in real values.
# These names must match the *_env fields in configs/arywen.yaml.
ARYWEN_TESTNET_SASL=changeme
ARYWEN_LIBERA_SASL=changeme
# Twitch chat oauth token; the "oauth:" prefix is added automatically if omitted.
ARYWEN_TWITCH_TOKEN=changeme
# Discord bot token (from the Discord developer portal).
ARYWEN_DISCORD_TOKEN=changeme
# Botnet bus (Redis) password. Leave empty for the default auth-less in-cluster Redis.
REDIS_PASSWORD=
